{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/a7a65dd6-f43d-43df-a331-dcfdce6f0a5e')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/a7a65dd6-f43d-43df-a331-dcfdce6f0a5e')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "LAB05 - Encoded PowerShell (decoded payload present)",
                "description": "Detects Sysmon EID 1 PowerShell with EncodedCommand and decodes payload from RenderedDescription.",
                "severity": "High",
                "enabled": true,
                "query": "Event\r\n| where TimeGenerated > ago(1h)\r\n| where Computer has \"win-ws1\"\r\n| where EventLog == \"Microsoft-Windows-Sysmon/Operational\"\r\n| where EventID == 1\r\n| where RenderedDescription has \"EncodedCommand\"\r\n| extend EncodedBlob = extract(@\"(?i)(?:-enc(?:odedcommand)?\\s+)([A-Za-z0-9+/=]+)\", 1, RenderedDescription)\r\n| where isnotempty(EncodedBlob)\r\n| extend DecodedRaw = base64_decode_tostring(EncodedBlob)\r\n| extend Decoded = replace_regex(DecodedRaw, @\"\\x00\", \"\")\r\n| project TimeGenerated, Computer, EncodedBlob, Decoded, RenderedDescription\r\n| sort by TimeGenerated desc",
                "queryFrequency": "PT5M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "Execution"
                ],
                "techniques": [
                    "T1059"
                ],
                "subTechniques": [
                    "T1059.001"
                ],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": false,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": null,
                "entityMappings": [
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "HostName",
                                "columnName": "Computer"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}